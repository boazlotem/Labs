<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="258.0" prefWidth="378.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lab3.LoginController">
   <center>
      <Label fx:id="welcomeLabel" alignment="CENTER" contentDisplay="CENTER" text="Welcome!" textAlignment="CENTER" textFill="RED">
         <font>
            <Font size="21.0" />
         </font>
      </Label>
   </center>
   <bottom>
      <Button fx:id="LogOut" mnemonicParsing="false" onAction="#handleLogOut" text="log out" translateY="-70.0" BorderPane.alignment="TOP_CENTER" />
   </bottom>
</BorderPane>
